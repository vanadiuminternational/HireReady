# GradSharp backend production environment example
# Copy to backend/.env on the VPS and replace placeholder values.

NODE_ENV=production
PORT=8787

# Set to the deployed frontend/app origin where possible.
# During Android-only testing, this can be permissive temporarily, but tighten before production.
CORS_ORIGIN=*

# AI remains mock-only until live provider, privacy, Data Safety, and credit controls are ready.
AI_LIVE_ENABLED=false
AI_PROVIDER=mock

# SQLite is suitable for early VPS mock/backend testing.
STORAGE_DRIVER=sqlite
SQLITE_PATH=./data/gradsharp.sqlite

# Required for protected debug stats in production.
# Generate a long random value and keep it private.
DEBUG_STATS_TOKEN=replace-with-long-random-secret

# Placeholder cap. Real provider-cost enforcement must be added before live AI.
PLATFORM_MONTHLY_COST_CAP_CENTS=2500
