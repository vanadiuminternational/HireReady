# HireReady backend environment

# Runtime
NODE_ENV=production
PORT=8787

# CORS
# For local development:
# CORS_ORIGIN=*
# For production, set this to the Android/web origin or deployed frontend origin where applicable.
CORS_ORIGIN=*

# AI mode
# Keep false until live provider adapter, persistent credits, cost caps, and privacy/Data Safety updates are complete.
AI_LIVE_ENABLED=false
AI_PROVIDER=mock

# Platform cost guard placeholder
# This is not yet enforced as persistent billing. It documents the intended monthly cap.
PLATFORM_MONTHLY_COST_CAP_CENTS=2500
